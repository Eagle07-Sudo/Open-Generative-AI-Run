{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "catalogInputSchema",
  "title": "Model catalog input field",
  "description": "Shared contract for model control metadata (ADR-008). Used by Model Input Resolver.",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["string", "number", "int", "boolean"]
    },
    "title": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "default": {},
    "enum": {
      "type": "array",
      "items": {}
    },
    "minValue": { "type": "number" },
    "maxValue": { "type": "number" },
    "step": { "type": "number" }
  },
  "required": ["name"]
}
